{
  "name": "test",
  "version": "2.1-SNAPSHOT",
  "description": "Javascript webpack libraries",
  "main": "./src/main/resources/webpack",
  "scripts": {
    "global-install": "npm prune && npm install --no-optional -g webpack webpack-dev-server",
    "build": "npm run build:production",
    "build:development": "webpack --config webpack.config.js --mode development",
    "build:watch": "webpack --config webpack.config.js --watch --mode development",
    "build:production": "webpack --config webpack.config.js --mode production",
    "start": "mvn spring-boot:run",
    "start:hot-reload": "concurrently -k -n watch,app -c cyan,green \"npm run build:watch\" \"mvn spring-boot:run -Phot-reload -Dspring-boot.run.profiles=hot-reload\""
  },
  "license": "ISC",
  "dependencies": {
    "webpack": "^5.72.1",
    "webpack-cli": "^5.1.4",
    "less": "^3.11.0",
    "less-loader": "^7.3.0",
    "less-plugin-autoprefix": "^2.0.0",
    "mini-css-extract-plugin": "^1.5.0",
    "exports-loader": "^2.0.0",
    "expose-loader": "^2.0.0",
    "css-loader": "^3.4.2",
    "babel-loader": "^8.0.6",
    "babel-plugin-array-includes": "^2.0.3",
    "babel-plugin-istanbul": "^6.0.0",
    "babel-plugin-object-values-to-object-keys": "^1.0.2",
    "babel-plugin-transform-object-entries": "^1.0.0",
    "@babel/core": "^7.8.4",
    "@babel/plugin-proposal-object-rest-spread": "^7.8.3",
    "@babel/plugin-transform-object-assign": "^7.8.3",
    "@babel/preset-env": "^7.8.4",
    "@babel/types": "^7.8.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
