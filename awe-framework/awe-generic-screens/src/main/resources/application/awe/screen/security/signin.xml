<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://aweframework.gitlab.io/awe/docs/schemas/screen.xsd" template="full" label="SCREEN_TITLE_LOGIN" help="HELP_SCREEN_TITLE_LOGIN">
  <tag source="center" type="div" style="fullScreen">
    <tag type="div" id="page-signin-bg" style="fullScreen">
      <!-- Background overlay -->
      <tag type="div" style="overlay-image fullScreen" />
      <tag type="div" style="overlay fullScreen" />
    </tag>
    <tag type="div" style="awe-signin signin-container">

      <!-- Left side -->
      <tag type="div" style="signin-info">
        <tag type="h1">
          <tag type="span" label="APP_CLIENT"/>
        </tag>
        <tag type="div" style="slogan" label="APP_NAME" />
      </tag>
      <!-- / Left side -->

      <!-- Right side -->
      <tag type="div" style="signin-form">
        <tag type="div" style="signin-text">
          <tag type="span" label="SCREEN_TITLE_LOGIN"/>
        </tag>
        <criteria placeholder="SCREEN_TEXT_USER" component="text" id="cod_usr" validation="required" size="lg" icon="user signin-form-icon" style="no-label" />
        <criteria placeholder="SCREEN_TEXT_PASS" component="password" id="pwd_usr" validation="required" size="lg" icon="key signin-form-icon" style="no-label" />
        <tag type="div" style="signin-with">
          <tag type="div" style="form-actions">
            <button button-type="submit" label="BUTTON_LOGIN" style="no-class btn btn-awe btn-primary signin-btn bg-primary" icon="sign-in" id="ButLogIn">
              <button-action type="validate" />
              <button-action type="server" server-action="login" />
            </button>
            <!-- Azure EntraID -->
            <button id="ButLogInAzure" style="no-class sign-in-azure-btn-light" >
              <dependency target-type="hide" initial="true" type="or">
                <dependency-element id="azure-enabled" condition="eq" value="false"/>
                <dependency-element id="azure-enabled" condition="is empty"/>
              </dependency>
              <button-action type="server" server-action="login-azure"/>
            </button>
            <!-- Sign with SSO -->
            <button id="ButLogInSSO" style="no-class btn btn-awe btn-dark signin-btn sign-in-sso-btn" label="BUTTON_LOGIN_SSO">
              <dependency target-type="hide" initial="true" type="or">
                <dependency-element id="sso-enabled" condition="eq" value="false"/>
                <dependency-element id="sso-enabled" condition="is empty"/>
              </dependency>
              <button-action type="server" server-action="login-sso"/>
            </button>
          </tag>
        </tag>
      </tag>
      <!-- Right side -->
    </tag>
  </tag>
  <tag source="hidden">
    <criteria id="azure-enabled" component="text" property="awe.security.sso.enable-azure-button"/>
    <criteria id="sso-enabled" component="text" property="awe.security.sso.enable-generic-sso-button"/>
  </tag>
</screen>